                                  manual_k=False, k_value=3)


@app.route("/analyze", methods=["POST"])
def analyze():
    """
    1. Read uploaded CSV.
    2. Identify numeric columns.
    3. Preprocess (impute + scale).
    4. Run elbow method (or use manual k).
    5. Fit final KMeans.
    6. Build plots and summary.
    7. Render results page.
    """
    # ── 1. Receive file ──────────────────────────────────
    file = request.files.get("csv_file")
    if file is None or file.filename == "":
        return render_template_string(INDEX_TEMPLATE,
                                      error="No file uploaded. Please select a CSV.",
                                      manual_k=False, k_value=3)

    try:
        df = pd.read_csv(file)
    except Exception as exc:
        return render_template_string(INDEX_TEMPLATE,
                                      error=f"Could not parse CSV: {exc}",
                                      manual_k=False, k_value=3)

    if df.empty:
        return render_template_string(INDEX_TEMPLATE,
                                      error="The uploaded CSV is empty.",
                                      manual_k=False, k_value=3)

    # ── 2. Select numeric columns ────────────────────────
    num_df = df.select_dtypes(include=[np.number])
    if num_df.shape[1] < 2:
        return render_template_string(INDEX_TEMPLATE,
                                      error="Need at least 2 numeric columns for clustering.",
                                      manual_k=False, k_value=3)

    feature_cols = num_df.columns.tolist()

    # ── 3. Preprocessing ─────────────────────────────────
    # Fill missing values with column median
    num_df = num_df.fillna(num_df.median())

    # Scale features to zero mean, unit variance
    scaler   = StandardScaler()
    X_scaled = scaler.fit_transform(num_df.values)

    # ── 4. Determine k ───────────────────────────────────
    manual_k   = "manual_k" in request.form
    k_value    = int(request.form.get("k_value", 3))

    K_MAX = 10
    if manual_k:
        optimal_k = max(2, min(k_value, len(df) - 1, K_MAX))
        # Still compute inertias for the elbow plot
        _, inertias = find_optimal_k(X_scaled, k_max=K_MAX)
        method = "manual"
    else:
        optimal_k, inertias = find_optimal_k(X_scaled, k_max=K_MAX)
        method = "auto"

    # ── 5. Final KMeans ──────────────────────────────────
    km     = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
    labels = km.fit_predict(X_scaled)

    # Silhouette score (meaningful only for k >= 2)
    try:
        sil = round(silhouette_score(X_scaled, labels), 3)
    except Exception:
        sil = "N/A"

    # ── 6. Plots ─────────────────────────────────────────
    elbow_plot   = plot_elbow(inertias, optimal_k, k_max=K_MAX)
    scatter_plot = plot_clusters(X_scaled, labels, optimal_k)

    # ── 7. Data preview (first 10 rows) ──────────────────
    preview_df         = num_df.head(10).copy()
    preview_df["Cluster"] = labels[:10]

    table_cols = feature_cols
    table_rows = [
        [round(v, 2) if isinstance(v, float) else v
         for v in row.tolist()]
        for _, row in preview_df.iterrows()
    ]

    # ── 8. Cluster summary ───────────────────────────────
    full_df           = num_df.copy()
    full_df["Cluster"] = labels
    grp                = full_df.groupby("Cluster")

    summary_rows = []
    for c in range(optimal_k):
        g    = grp.get_group(c)
        means = [round(g[col].mean(), 2) for col in feature_cols]
        summary_rows.append([c] + means + [len(g)])

    # ── Colour map for badges ────────────────────────────
    cluster_colors = {i: BADGE_COLORS[i % len(BADGE_COLORS)]
                      for i in range(optimal_k)}

    return render_template_string(
        RESULTS_TEMPLATE,
        n_clusters    = optimal_k,
        n_rows        = len(df),
        n_features    = len(feature_cols),
        silhouette    = sil,
        feature_cols  = feature_cols,
        elbow_plot    = elbow_plot,
        scatter_plot  = scatter_plot,
        table_cols    = table_cols,
        table_rows    = table_rows,
        summary_rows  = summary_rows,
        cluster_colors= cluster_colors,
        method        = method,
    )


