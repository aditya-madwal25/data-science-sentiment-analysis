# ─────────────────────────────────────────────────────────
#  Helper: matplotlib figure → base64 PNG string
# ─────────────────────────────────────────────────────────
def fig_to_base64(fig):
    """Convert a Matplotlib figure to a base-64-encoded PNG string."""
    buf = io.BytesIO()
    fig.savefig(buf, format="png", dpi=110, bbox_inches="tight",
                facecolor=fig.get_facecolor())
    buf.seek(0)
    encoded = base64.b64encode(buf.read()).decode("utf-8")
    plt.close(fig)
    return encoded


# ─────────────────────────────────────────────────────────
#  Helper: Elbow Method — find optimal k
# ─────────────────────────────────────────────────────────
def find_optimal_k(X, k_max=10):
    """
    Compute inertia for k = 2 … k_max and detect the 'elbow'
    using the maximum second-derivative (kneedle-lite approach).
    Returns (optimal_k, list_of_inertias).
    """
    k_range = range(2, min(k_max + 1, len(X)))  # can't have more clusters than rows
    inertias = []

    for k in k_range:
        km = KMeans(n_clusters=k, random_state=42, n_init=10)
        km.fit(X)
        inertias.append(km.inertia_)

    # Second-derivative heuristic to find the elbow index
    if len(inertias) < 3:
        return list(k_range)[0], inertias

    diffs1 = np.diff(inertias)          # first derivative
    diffs2 = np.diff(diffs1)            # second derivative
    elbow_idx = int(np.argmax(diffs2)) + 2   # +2 because k starts at 2 & two diffs
    optimal_k = list(k_range)[elbow_idx]

    return optimal_k, inertias


# ─────────────────────────────────────────────────────────
#  Helper: plot elbow curve
# ─────────────────────────────────────────────────────────
def plot_elbow(inertias, optimal_k, k_max=10):
    """Return base-64 PNG of the elbow curve."""
    k_range = range(2, min(k_max + 1, len(inertias) + 2))
    fig, ax = plt.subplots(figsize=(7, 4), facecolor="#1e293b")
    ax.set_facecolor("#0f172a")

    ax.plot(list(k_range), inertias, "o-", color="#818cf8",
            linewidth=2.2, markersize=7, markerfacecolor="#c4b5fd")
    ax.axvline(optimal_k, color="#f43f5e", linestyle="--",
               linewidth=1.8, label=f"Optimal k = {optimal_k}")

    ax.set_xlabel("Number of Clusters (k)", color="#94a3b8")
    ax.set_ylabel("Inertia", color="#94a3b8")
    ax.set_title("Elbow Method", color="#e2e8f0", fontsize=13, fontweight="bold")
    ax.tick_params(colors="#64748b")
    for spine in ax.spines.values():
        spine.set_edgecolor("#334155")
    ax.legend(facecolor="#1e293b", edgecolor="#334155",
              labelcolor="#e2e8f0", fontsize=9)
    fig.tight_layout()
    return fig_to_base64(fig)


# ─────────────────────────────────────────────────────────
#  Helper: 2-D scatter plot (PCA)
# ─────────────────────────────────────────────────────────
def plot_clusters(X_scaled, labels, n_clusters):
    """Project X to 2-D via PCA and plot coloured clusters."""
    pca = PCA(n_components=2, random_state=42)
    X2d = pca.fit_transform(X_scaled)

    palette = cm.get_cmap("tab10", n_clusters)
    colors  = [palette(i) for i in range(n_clusters)]

    fig, ax = plt.subplots(figsize=(7, 5), facecolor="#1e293b")
    ax.set_facecolor("#0f172a")

    for c in range(n_clusters):
        mask = labels == c
        ax.scatter(X2d[mask, 0], X2d[mask, 1],
                   color=colors[c], s=50, alpha=0.78,
                   edgecolors="none", label=f"Cluster {c}")

    ax.set_xlabel("PCA Component 1", color="#94a3b8")
    ax.set_ylabel("PCA Component 2", color="#94a3b8")
    ax.set_title("Customer Segments (PCA Projection)",
                 color="#e2e8f0", fontsize=13, fontweight="bold")
    ax.tick_params(colors="#64748b")
    for spine in ax.spines.values():
        spine.set_edgecolor("#334155")
    ax.legend(facecolor="#1e293b", edgecolor="#334155",
              labelcolor="#e2e8f0", fontsize=9, markerscale=1.4)
    fig.tight_layout()
    return fig_to_base64(fig)


